plugins {
	id 'nf-ga4gh'
}
process {
	executor = 'tes'
	container = 'quay.io/cdis/gen3-workflow:integration_tests_dicom_image'
	// this test tends to fail intermittently; improve stability with retries for now:
	process.errorStrategy = 'retry'
	process.maxRetries = 2
	time = '20 min'  // task timeout
}
tes {
	endpoint = "${env('HOSTNAME_PROTOCOL')}://${env('HOSTNAME')}/ga4gh/tes"
	oauthToken = env('GEN3_TOKEN')
	timeout = 120
}
aws {
	accessKey = env('GEN3_TOKEN')
	secretKey = 'N/A'
	region = 'us-east-1'
	client {
		endpoint = "${env('HOSTNAME_PROTOCOL')}://${env('HOSTNAME')}/workflows/s3"
		s3PathStyleAccess = true
		maxErrorRetry = 1
    }
}
workDir = env('WORK_DIR')
